# Descope Project ID (required)
DESCOPE_PROJECT_ID=your-descope-project-id

# Descope Management Key (required for admin operations)
DESCOPE_MANAGEMENT_KEY=your-management-key

# Database URL (default: postgresql+asyncpg://identity:dev@postgres:5432/identity)
# DATABASE_URL=postgresql+asyncpg://identity:dev@postgres:5432/identity

# Postgres password for docker-compose (default: dev)
# POSTGRES_PASSWORD=dev

# OpenTelemetry OTLP exporter endpoint (default: Aspire dashboard in docker-compose)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire-dashboard:18889

# OpenTelemetry service name
# OTEL_SERVICE_NAME=identity-stack-backend

# Redis URL (default: redis://redis:6379/0)
# REDIS_URL=redis://redis:6379/0

# Environment: "development" or "production" (affects security headers)
# ENVIRONMENT=development

# Content-Security-Policy header (override default per environment)
# CSP_POLICY=default-src 'self'

# Frontend URL for CORS (default: http://localhost:3000)
# FRONTEND_URL=http://localhost:3000

# Rate limiting (uses slowapi format: "count/period", e.g. "60/minute", "10/second")
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_AUTH=10/minute
