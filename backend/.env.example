# Descope Project ID (required)
DESCOPE_PROJECT_ID=your-descope-project-id

# Descope Management Key (required for admin operations)
DESCOPE_MANAGEMENT_KEY=your-management-key

# Database URL (required — app will not start without this)
# Must use an async driver (e.g. postgresql+asyncpg://)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/identity

# PostgreSQL password for docker-compose (required for `docker compose up`)
# POSTGRES_PASSWORD=your-secure-password

# Redis password for docker-compose (default: changeme)
# REDIS_PASSWORD=your-secure-password

# Environment: "development" or "production" (affects security headers)
# ENVIRONMENT=development

# Content-Security-Policy header (override default per environment)
# CSP_POLICY=default-src 'self'

# Frontend URL for CORS (default: http://localhost:3000)
# FRONTEND_URL=http://localhost:3000

# Rate limiting (uses slowapi format: "count/period", e.g. "60/minute", "10/second")
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_AUTH=10/minute

# OpenTelemetry (Aspire Dashboard)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire-dashboard:18889
# OTEL_SERVICE_NAME=identity-stack-backend

# Redis URL (default: redis://redis:6379/0)
# REDIS_URL=redis://redis:6379/0

# Deployment mode: "standalone" (default) or "gateway"
# In gateway mode, Tyk handles JWT validation and rate limiting;
# TokenValidationMiddleware and SlowAPIMiddleware are skipped.
# DEPLOYMENT_MODE=standalone

# Tyk Gateway secret (required for gateway profile)
# Must match the secret in tyk/tyk.conf. Used by docker-compose env var substitution.
# TYK_GATEWAY_SECRET=your-tyk-gateway-secret
